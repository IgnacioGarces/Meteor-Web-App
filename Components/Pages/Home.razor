<!-- SCROLLSPY -->
<script>
    document.addEventListener('DOMContentLoaded', function () { 
        const scrollContainer = document.querySelector('.snap-container');

        new bootstrap.ScrollSpy(scrollContainer, {
            target: '#mainNavbar',
            offset: 80
        });
    });
</script>

@code {
    private ContactFormModel form = new();
    private bool enviando = false;
    private bool enviado = false;

    [Inject]
    private IEmailService EmailService { get; set; } = default!;

    private async Task EnviarFormulario()
    {
        enviando = true;
        enviado = false;

        await EmailService.SendAsync(form);

        enviado = true;
        enviando = false;

        form = new ContactFormModel(); 
    }
}
