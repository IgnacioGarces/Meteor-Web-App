    <!-- CONTACTO -->
    <section id="contacto" class="snap-section ">

        <div class="card mb-3" style="max-width: 1920px;">
            <div class="row g-0">

                <!-- TEXTO -->
                <div class="col-12 col-md-5 d-flex align-items-center">
                    <div class="card-body">
                        <h2 class="fw-bold fs-3 fs-md-1 mb-4">
                            Contactanos
                        </h2>

                        <p class="lh-base fs-6 fs-md-4 mb-0">
                            ¿Tenés un proyecto en mente?<br>
                            Nos especializamos en transformar ideas en experiencias visuales únicas.
                        </p>
                    </div>
                </div>

                <!-- FORM -->
                <EditForm Model="form"
                          OnValidSubmit="EnviarFormulario"
                          FormName="contactForm"
                          Enhance="true">

                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label fs-6 fs-md-5">Nombre</label>
                        <InputText @bind-Value="form.Nombre"
                                   class="form-control form-control-lg"
                                   placeholder="Tu nombre" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fs-6 fs-md-5">Email</label>
                        <InputText @bind-Value="form.Email"
                                   type="email"
                                   class="form-control form-control-lg"
                                   placeholder="tu@email.com" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fs-6 fs-md-5">Mensaje</label>
                        <InputTextArea @bind-Value="form.Mensaje"
                                       class="form-control form-control-lg"
                                       rows="4"
                                       placeholder="Contanos sobre tu proyecto..." />
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit"
                                class="btn btn-outline-light btn-lg px-5"
                                disabled="@enviando">
                            @(enviando ? "Enviando..." : "Enviar")
                        </button>
                    </div>

                </EditForm>

                @if (enviado)
                {
                    <div class="alert alert-success mb-4">
                        ¡Gracias! Tu mensaje fue enviado correctamente.
                    </div>
                }

            </div>
        </div>

        <footer class="contact-footer">
            <span class="footer-title">FOLLOW US</span>

            <div class="social-icons">
                <a href="https://www.instagram.com/meteor_craftwork" target="_blank" aria-label="Instagram">
                    <i class="bi bi-instagram"></i>
                </a>

                <a href="https://www.facebook.com/profile.php?id=61574530960294" target="_blank" aria-label="Facebook">
                    <i class="bi bi-facebook"></i>
                </a>

                <a href="https://www.linkedin.com/company/meteorcraftwork/?viewAsMember=true" target="_blank" aria-label="LinkedIn">
                    <i class="bi bi-linkedin"></i>
                </a>

                <a href="https://discord.com/invite/bY4T7QxtyJ" target="_blank" aria-label="Discord">
                    <i class="bi bi-discord"></i>
                </a>
                <a href="https://www.artstation.com/meteorcraftwork" target="_blank" aria-label="ArtStation" class="artstation-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" role="img" aria-hidden="true">
                        <path d="M2.5 18.6l1.4 2.4h16.4l1.4-2.4H2.5zm9.7-15L7.2 15.2h9.6L12.2 3.6zm2.3 11.6l-2.3-4-2.3 4h4.6z" />
                    </svg>
                </a>
               
            </div>
        </footer>
