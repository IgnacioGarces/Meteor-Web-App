    <!-- CONTACTO -->
    <section id="contacto" class="snap-section ">

        <div class="card-contact mb-3" style="max-width: 1920px;">
            <div class="row g-0">

                <!-- TEXTO -->
                <div class="contact-text col-12 col-md-5 ">
                    <div class="contact-card-body">
                        <h4 class="card-text title">
                            Contact
                        </h4>

                        <p class=" contact-card-text ">
                            ¿Ready to start your next project?<br>
                            We specialize in turning ideas into unique visual experiences.
                        </p>
                    </div>
                </div>

                <!-- FORM -->
                <div class="col-12 col-md-7 p-4">

                    <EditForm Model="form"
                              OnValidSubmit="EnviarFormulario"
                              FormName="contactForm"
                              >

                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger mb-3" />

                        <div class="form-inputs">
                            <label class="form-label">Nombre</label>
                            <InputText @bind-Value="form.Nombre" name="Nombre"
                                       class="form-control form-control-lg" />
                        </div>

                        <div class="form-inputs ">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="form.Email"
                                       name="Email"
                                       type="email"
                                       class="form-control form-control-lg" />
                        </div>

                        <div class="form-inputs">
                            <label class="form-label">Mensaje</label>
                            <InputTextArea @bind-Value="form.Mensaje"
                                            name ="Mensaje"
                                           class="form-control form-control-lg"
                                           rows="4" />
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit"
                                    class="btn btn-outline-light btn-lg px-5"
                                    disabled="@enviando">
                                @(enviando ? "Enviando..." : "Enviar")
                            </button>
                        </div>

                    </EditForm>

                    @if (enviado)
                    {
                        <div class="alert alert-success mt-3">
                            ¡Gracias! Tu mensaje fue enviado correctamente.
                        </div>
                    }
                </div>

            </div>
        </div>

        
