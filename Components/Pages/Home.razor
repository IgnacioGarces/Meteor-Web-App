@page "/"

<!-- NAVBAR -->
<nav id="mainNavbar" class="navbar navbar-expand-md navbar-dark bg-dark fixed-top py-1">
    <div class="container-fluid">

        <a class="navbar-brand mb-0 h1" href="#top">
            METEOR CRAFTWORKS
        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="#lanzamientos">Lanzamientos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#about">Devs</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#contacto">Contacto</a>
                </li>
            </ul>
        </div>

    </div>
</nav>

<!-- SCROLLSPY CONTAINER -->
<div data-bs-spy="scroll"
     data-bs-target="#mainNavbar"
     data-bs-offset="80"
     data-bs-smooth-scroll="true"
     tabindex="0">

    <!-- TOP ANCHOR -->
    <div id="top"></div>

    <!-- LANZAMIENTOS -->
    <section id="lanzamientos" class="pt-5 mt-5">

        <div id="carouselExampleAutoplaying" class="carousel carousel-dark slide m-xxl-1" data-bs-ride="carousel">

            <div class="carousel-indicators">
                <button type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide-to="2"></button>
            </div>

            <div class="carousel-inner">

                <div class="carousel-item active">
                    <div class="ratio ratio-21x9">
                        <img src="/imgs/imgCarrusel2.png" class="d-block w-100 object-fit-cover rounded" alt="">
                    </div>
                    <div class="carousel-caption d-none d-md-block">
                        <h5 class="fs-1">Artistas capaces</h5>
                        <p class="fs-3">
                            This is a long paragraph written to show how the line-height of an element is affected.
                        </p>
                    </div>
                </div>

                <div class="carousel-item">
                    <div class="ratio ratio-21x9">
                        <img src="/imgs/imgCarrusel1.png" class="d-block w-100 object-fit-cover rounded" alt="">
                    </div>
                    <div class="carousel-caption d-none d-md-block">
                        <h5 class="fs-1">Del concepto a la implementación</h5>
                        <p class="fs-3">Hacemos de lo imposible algo real y tangible.</p>
                    </div>
                </div>

                <div class="carousel-item">
                    <div class="ratio ratio-21x9">
                        <img src="/imgs/imgCarrusel3.png" class="d-block w-100 object-fit-cover rounded" alt="">
                    </div>
                    <div class="carousel-caption d-none d-md-block">
                        <h5 class="fs-1">Diseños y atmósferas</h5>
                        <p class="fs-3">Storytelling y ambientación de alto nivel.</p>
                    </div>
                </div>

            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>

        </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="pt-5">

        <div class="card mb-3 ratio ratio-21x9" style="max-width: 1920px;">
            <div class="row g-0">
                <div class="col-md d-flex justify-content-center align-items-center">
                    <img src="/imgs/logo.png" width="560" height="560" class="img-fluid rounded-start" alt="">
                </div>

                <div class="col-md-8 align-content-center">
                    <div class="card-body">
                        <h5 class="card-title text-center fs-1 fw-bold">About us</h5>
                        <p class="card-text fs-3 lh-base">
                            This is a wider card with supporting text below as a natural lead-in to additional content.
                        </p>
                        <p class="card-text text-end fs-6">
                            <small class="text-body-secondary">Last updated 3 mins ago</small>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- DEVS -->
        <div class="card mb-3 ratio ratio-21x9" style="max-width: 1920px;">
            <div class="row row-cols-1 row-cols-md-3 g-4">

                <div class="col">
                    <div class="card max-width: 560px max-height: 560px">
                        <img src="/imgs/pic-angry.png" class="card-img-top  " alt="...">
                        <div class="card-body">
                            <h5 class="card-title">Card title</h5>
                            <p class="card-text">This is a longer card with supporting text below as a natural lead-in to additional content. This content is a little bit longer.</p>
                        </div>
                    </div>
                </div>

                <div class="col">
                    <div class="card">
                        <img src="..." class="card-img-top" alt="...">
                        <div class="card-body">
                            <h5 class="card-title">Card title</h5>
                            <p class="card-text">This is a longer card with supporting text below as a natural lead-in to additional content. This content is a little bit longer.</p>
                        </div>
                    </div>
                </div>

                <div class="col">
                    <div class="card">
                        <img src="..." class="card-img-top" alt="...">
                        <div class="card-body">
                            <h5 class="card-title">Card title</h5>
                            <p class="card-text">This is a longer card with supporting text below as a natural lead-in to additional content.</p>
                        </div>
                    </div>
                </div>

                <div class="col">
                    <div class="card">
                        <img src="..." class="card-img-top" alt="...">
                        <div class="card-body">
                            <h5 class="card-title">Card title</h5>
                            <p class="card-text">This is a longer card with supporting text below as a natural lead-in to additional content. This content is a little bit longer.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </section>

    <!-- CONTACTO -->
    <section id="contacto" class="pt-5 pb-5">

        <div class="card mb-3 ratio ratio-21x9" style="max-width: 1920px;">
            <div class="row g-0 h-100">

                <!-- TEXTO -->
                <div class="col-md-5 d-flex align-items-center">
                    <div class="card-body">
                        <h2 class="fs-1 fw-bold mb-4">Contactanos</h2>

                        <p class="fs-4 lh-base">
                            ¿Tenés un proyecto en mente?
                            Nos especializamos en transformar ideas en experiencias visuales únicas.
                        </p>

                    </div>
                </div>

                <!-- FORM -->
                <div class="col-md-7 d-flex align-items-center">
                    <div class="card-body w-100">

                        <form action="mailto:meteorcraftwork@gmail.com"
                              method="post"
                              enctype="text/plain">

                            <div class="mb-3">
                                <label class="form-label fs-5">Nombre</label>
                                <input type="text"
                                       name="Nombre"
                                       class="form-control form-control-lg"
                                       placeholder="Tu nombre"
                                       required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fs-5">Email</label>
                                <input type="email"
                                       name="Email"
                                       class="form-control form-control-lg"
                                       placeholder="tu@email.com"
                                       required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fs-5">Mensaje</label>
                                <textarea name="Mensaje"
                                          class="form-control form-control-lg"
                                          rows="4"
                                          placeholder="Contanos sobre tu proyecto..."
                                          required></textarea>
                            </div>

                            <div class="d-flex justify-content-end">
                                <button type="submit"
                                        class="btn btn-outline-light btn-lg px-5">
                                    Enviar
                                </button>
                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>

    </section>

</div>

<!-- SCROLLSPY -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        new bootstrap.ScrollSpy(document.body, {
            target: '#mainNavbar',
            offset: 80
        })
    })
</script>