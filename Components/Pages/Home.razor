@inject IJSRuntime JS
@inject NavigationManager Nav

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
        await JS.InvokeVoidAsync("initActiveSections");
        await JS.InvokeVoidAsync("enableNavScroll");
        await JS.InvokeVoidAsync("scrollToHash");
        }
    }

    private IEnumerable<ArticleModel> articulos = Array.Empty<ArticleModel>();
    private IEnumerable<ProductModel> productos = Array.Empty<ProductModel>();

    protected override void OnInitialized()
    {
        articulos = ArticleService.GetAll();
        productos = ProductService.GetAll(); 
    }
    

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = HandleLocationChangedAsync(e);
    }

    private async Task HandleLocationChangedAsync(LocationChangedEventArgs e)
    {
        try
        {
            await JS.InvokeVoidAsync("scrollToHash");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
    }

    public void Dispose()
    {
        //Nav.LocationChanged -= OnLocationChanged;
    }



    private ContactFormModel form = new();
    private bool enviando = false;
    private bool enviado = false;

    [Inject]
    private IEmailService EmailService { get; set; } = default!;

    private async Task EnviarFormulario()
    {
        enviando = true;
        enviado = false;

        try
        {
            await EmailService.SendAsync(form);
            enviado = true;
            form = new ContactFormModel();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            enviando = false;
            StateHasChanged();
        }
    }
}

