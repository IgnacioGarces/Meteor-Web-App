    <!-- CONTACTO -->
    <section id="contacto" class="pt-5 pb-5">

        <div class="card mb-3" style="max-width: 1920px;">
            <div class="row g-0">

                <!-- TEXTO -->
                <div class="col-12 col-md-5 d-flex align-items-center">
                    <div class="card-body">
                        <h2 class="fw-bold fs-3 fs-md-1 mb-4">
                            Contactanos
                        </h2>

                        <p class="lh-base fs-6 fs-md-4 mb-0">
                            ¿Tenés un proyecto en mente?<br>
                            Nos especializamos en transformar ideas en experiencias visuales únicas.
                        </p>
                    </div>
                </div>

                <!-- FORM -->
                <div class="col-12 col-md-7 d-flex align-items-center">
                    <div class="card-body w-100">

                        <form action="mailto:meteorcraftwork@gmail.com"
                              method="get">

                            <div class="mb-3">
                                <label class="form-label fs-6 fs-md-5">Nombre</label>
                                <input type="text"
                                       name="Nombre"
                                       class="form-control form-control-lg"
                                       placeholder="Tu nombre"
                                       required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fs-6 fs-md-5">Email</label>
                                <input type="email"
                                       name="Email"
                                       class="form-control form-control-lg"
                                       placeholder="tu@email.com"
                                       required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fs-6 fs-md-5">Mensaje</label>
                                <textarea name="Mensaje"
                                          class="form-control form-control-lg"
                                          rows="4"
                                          placeholder="Contanos sobre tu proyecto..."
                                          required></textarea>
                            </div>

                            <div class="d-flex justify-content-end">
                                <button type="submit"
                                        class="btn btn-outline-light btn-lg px-5">
                                    Enviar
                                </button>
                            </div>

                            <small class="text-body-secondary d-block mt-2">
                                Se abrirá tu cliente de correo para enviar el mensaje.
                            </small>

                        </form>

                    </div>
                </div>

            </div>
        </div>

    </section>

