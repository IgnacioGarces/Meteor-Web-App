@using MeteorWebApp.Models
@using MeteorWebApp.Services
@using System.ComponentModel.DataAnnotations
@inject ArticleService ArticleService
@inject ProductService ProductService
@page "/"
@rendermode InteractiveServer



<div class="home snap-container">

    <section id="lanzamientos" class="snap-section">
        
        <div id="carouselExampleAutoplaying"
         class="carousel carousel-dark slide container-fluid p-0 m-0"
         data-bs-ride="carousel">

        @{
            // 1. Calculamos el total de slides y preparamos nuestra bandera global
            int totalSlides = (productos?.Count() ?? 0) + (articulos?.Count() ?? 0);
            bool isFirst = true;
        }

        <div class="carousel-indicators">
            @for (int i = 0; i < totalSlides; i++)
            {
                <button type="button" 
                        data-bs-target="#carouselExampleAutoplaying" 
                        data-bs-slide-to="@i" 
                        class="@(i == 0 ? "active" : "")"
                        aria-current="@(i == 0 ? "true" : "false")">
                </button>
            }
        </div>

        <div class="carousel-inner">
            
            @* Bucle de Productos *@
            @if (productos != null && productos.Any())
            {
                @foreach (var prod in productos)
                {
                    <div class="carousel-item @(isFirst ? "active" : "")">
                        <div class="carousel-img-wrapper">
                            <a href="/product/@prod.Id">
                                <img src="@prod.Poster" class="d-block" alt="@prod.Title">
                            </a>
                        </div>
                        <div class="carousel-caption custom-caption">
                            <div class="caption-content text-start">
                                <p class="card-text">@prod.Description</p>
                            </div>
                        </div>
                    </div>
                    
                    { isFirst = false; } 
                }
            }

            @* Bucle de Artículos *@
            @if (articulos != null && articulos.Any())
            {
                @foreach (var article in articulos)
                {
                    <div class="carousel-item @(isFirst ? "active" : "")">
                        <div class="carousel-img-wrapper">
                            <a href="/article/@article.Id">
                                <img src="@article.FirstImageUrl" class="d-block" alt="@article.Title">
                            </a>
                        </div>
                        <div class="carousel-caption custom-caption">
                            <div class="caption-content text-start">
                                <p class="card-text ">@article.Description</p>
                            </div>
                        </div>
                    </div>
                    
                    { isFirst = false; }
                }
            }
            
        </div>

        <button class="carousel-control-prev" type="button"
                data-bs-target="#carouselExampleAutoplaying"
                data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next" type="button"
                data-bs-target="#carouselExampleAutoplaying"
                data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>

        </div>
